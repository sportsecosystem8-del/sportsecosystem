# Local dev: leave unset — Vite proxies /api and /uploads to the backend.
#
# Split deploy (Vercel frontend + Render/Railway API): set the full API base.
# Example: VITE_API_URL=https://YOUR-BACKEND.onrender.com/api
VITE_API_URL=

# Stripe publishable key (optional — coach/business platform subscriptions)
VITE_STRIPE_PUBLISHABLE_KEY=
