# Split deploy (Vercel SPA + Render API).
# Override VITE_API_URL in Vercel's Environment Variables dashboard
# with your actual Render backend URL after deploying.
VITE_API_URL=https://sports-ecosystem-api.onrender.com/api

# Optional — Stripe publishable key (set in Vercel dashboard)
VITE_STRIPE_PUBLISHABLE_KEY=
