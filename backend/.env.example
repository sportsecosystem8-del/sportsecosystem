# Copy to .env — never commit real secrets
MONGODB_URI=mongodb://127.0.0.1:27017/sports-ecosystem
JWT_SECRET=change-me
# e.g. 7d — use a sensible session length in production (avoid 3m for real users)
JWT_EXPIRES_IN=7d
ADMIN_PASSWORD=change-admin-login
ADMIN_EMAIL=admin@local.test
APP_BASE_URL=http://localhost:5173
# REQUIRED on deploy: public frontend URL for email verification & password reset links
# (e.g. https://yourapp.com — NOT localhost, or links fail on other devices)

# CORS — set to your deployed frontend origin in production
# CLIENT_URL=https://yourapp.com
# Production: Express serves frontend/dist and uses rate limits / combined logs
# NODE_ENV=production

# SMTP (required for email verification and password reset links)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# Prefer IPv4 for SMTP (avoids ENETUNREACH to IPv6 on some networks)
SMTP_PREFER_IPV4=true
# If port 587 fails (e.g. ETIMEDOUT), try once on 465/SSL. Set false to disable.
SMTP_TRY_SSL_PORT_FALLBACK=true
# Timeouts in ms (optional; defaults 20000 / 12000)
# SMTP_CONNECTION_TIMEOUT_MS=20000
# SMTP_GREETING_TIMEOUT_MS=12000

# AI providers (recommendations + training plan drafts)
# For OpenAI:
AI_PROVIDER=openai
OPENAI_API_KEY=
GROQ_API_KEY=
AI_MODEL_RECOMMENDATIONS=gpt-4o-mini
AI_MODEL_TRAINING_PLAN=gpt-4o-mini
# For Groq, set AI_PROVIDER=groq and use Groq-hosted model ids, e.g. llama-3.1-8b-instant.
# Example:
# AI_PROVIDER=groq
# AI_MODEL_RECOMMENDATIONS=llama-3.1-8b-instant
# AI_MODEL_TRAINING_PLAN=llama-3.1-8b-instant
AI_TIMEOUT_MS=8000
# Retries for 429/503 from the AI provider (backoff respects Retry-After when present)
AI_MAX_RETRIES=3
# Shorter budget for coach recommendations only (fail fast → baseline scores)
AI_REC_TIMEOUT_MS=4000
AI_REC_MAX_RETRIES=1
AI_RECOMMENDATIONS_ENABLED=true
AI_TRAINING_PLAN_ENABLED=true

# Rate limiting (production only by default). Set RATE_LIMIT_DISABLED=true to disable on a deployed env.
# Authenticated users are keyed by JWT sub — multiple users behind one IP each get their own quota.
# RATE_LIMIT_API_MAX=5000
# RATE_LIMIT_AUTH_MAX=150
# RATE_LIMIT_WINDOW_MS=900000

# MongoDB connection pool (Atlas / production)
# MONGODB_MAX_POOL_SIZE=50
# MONGODB_MIN_POOL_SIZE=5
# MONGODB_SERVER_SELECTION_TIMEOUT_MS=10000

# Behind nginx / Railway / Render — required for correct client IP in rate limits
# TRUST_PROXY=true

# PM2 cluster: npx pm2 start ecosystem.config.js (see repo root ecosystem.config.js)

# Stripe (optional) — platform subscriptions only (coach + business listing plans).
# Ground bookings and product orders use Easypaisa (see below).
STRIPE_SECRET_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=

# Easypaisa merchant (optional). Without keys, checkout runs in demo/mock mode for local dev.
EASYPAY_STORE_ID=
EASYPAY_HASH_KEY=
EASYPAY_API_URL=https://easypay.easypaisa.com.pk/easypay-service/rest/v4
