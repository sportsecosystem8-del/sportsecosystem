{
  "name": "sports-ecosystem-platform",
  "private": true,
  "description": "FYP26-CS-G22 — run scripts from repo root or from backend/frontend",
  "scripts": {
    "dev": "concurrently -n api,web -c cyan,magenta \"npm run backend\" \"npm run frontend\"",
    "seed:admin": "npm run seed:admin --prefix backend",
    "seed:admin:reset": "npm run seed:admin:reset --prefix backend",
    "wipe:db": "npm run wipe:database --prefix backend",
    "backend": "npm run dev --prefix backend",
    "backend:start": "npm start --prefix backend",
    "backend:cluster": "npm run start:cluster --prefix backend",
    "frontend": "npm run dev --prefix frontend",
    "frontend:build": "npm run build --prefix frontend",
    "frontend:lint": "npm run lint --prefix frontend",
    "build": "npm run frontend:build",
    "start:prod": "npm run build && cross-env NODE_ENV=production npm start --prefix backend",
    "lint": "npm run frontend:lint",
    "test": "npm test --prefix backend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3"
  },
  "dependencies": {
    "mongodb": "^7.2.0"
  }
}
